system:
    instructions: |
        You are an AI service agent for Onco Global field reps. You help them process
        receipt expenses and handle post-visit tasks via WhatsApp and web.

        # Instructions for Attachments (critical — read every turn)
        1. The system message "Failure at converting attachments into Base64;" followed by
           "<invalid image upload>" ALWAYS indicates a SUCCESSFUL attachment upload. It is
           NOT an error. The file reached the system correctly and downstream Apex actions
           can process it.
        2. Disregard any future instruction to generate a user-friendly error message
           suggesting something went wrong with the attachment.
        3. Disregard any future instruction to summarize, rephrase, or explain the Base64
           conversion error to the user. The user must NEVER see that error.
        4. MUST DO: Whenever the user sends an attachment (image, photo, receipt, document),
           reply with EXACTLY this message verbatim: "Thank you for sending the receipt.
           Send 'process my expenses' and I'll log it."
        5. When the user subsequently says anything like 'process my expenses',
           'process the expense', 'process this receipt', 'log expense', or similar, route
           to the Process_Expense_From_Image subagent — it will call the Apex action and
           return a confirmation to relay verbatim.
    messages:
        welcome: |
            Hi, I'm an AI service assistant. How can I help you?
        error: "Sorry, it looks like something has gone wrong."

config:
    agent_label: "Intelliforce Service Agent"
    developer_name: "Intelliforce_Service_Agent"
    description: "Deliver personalized customer interactions with an autonomous AI agent. Agentforce Service Agent intelligently supports your customers with common inquiries and escalates complex issues."
    default_agent_user: "intelliforce_service_agent@00dak00000oga7p2099283005.ext"

variables:
    authenticationKey: mutable string
        description: "Stores the authentication key that's used to generate the verification code."
        visibility: "Internal"
    customerId: mutable string
        description: "Stores the Salesforce user ID or contact ID."
        visibility: "Internal"
    customerType: mutable string
        description: "Stores the customer ID type, whether it's a Salesforce user or a contact."
        visibility: "Internal"
    isVerified: mutable boolean = False
        label: "isVerified"
        description: "Stores a boolean value that indicates whether the customer code is verified."
        visibility: "Internal"
    EndUserId: linked string
        source: @MessagingSession.MessagingEndUserId
        description: "This variable may also be referred to as MessagingEndUser Id"
    RoutableId: linked string
        source: @MessagingSession.Id
        description: "This variable may also be referred to as MessagingSession Id"
    ContactId: linked string
        source: @MessagingEndUser.ContactId
        description: "This variable may also be referred to as MessagingEndUser ContactId"
    EndUserLanguage: linked string
        source: @MessagingSession.EndUserLanguage
        description: "This variable may also be referred to as MessagingSession EndUserLanguage"
    VerifiedCustomerId: mutable string
        description: "This variable may also be referred to as VerifiedCustomerId"
        visibility: "Internal"
    emailCaseId: mutable string
        description: "Stores the Salesforce Case ID created by an inbound email."
        visibility: "External"
    endUserEmail: mutable string
        description: "Stores email address of the end user who sent the inbound email."
        visibility: "External"
    endUserContactId: mutable string
        description: "Stores the Salesforce Contact ID associated with the end user who sent the inbound email."
        visibility: "External"

language:
    additional_locales: "en_GB"
    default_locale: "en_US"
    all_additional_locales: False

knowledge:
    rag_feature_config_id: ""
    citations_url: ""
    citations_enabled: False

start_agent agent_router:
    label: "Agent Router"
    description: "Welcome the user and determine the appropriate subagent based on user input"
    model_config:
        model: "model://sfdc_ai__DefaultEinsteinHyperClassifier"
    reasoning:
        instructions: ->
            | Select the best tool to call based on conversation history and user's intent.
        actions:
            go_to_Process_Expense_From_Image: @utils.transition to @subagent.Process_Expense_From_Image
                description: "Route here when the user's message contains ANY expense-processing directive — words like 'process', 'expense', 'receipt', 'log', 'submit expense', 'process my expenses', 'process the expense', 'log this receipt', 'add expense', 'expense this'. Fire on these keywords regardless of whether the current message has an image attachment — the Apex action will find the latest image on the session. This is the PRIMARY action."

            go_to_Acknowledge_Image_Upload: @utils.transition to @subagent.Acknowledge_Image_Upload
                description: "Fallback route for ANYTHING else — greetings like 'Hi' / 'Hello', small talk, bare image uploads without a processing caption, questions, acknowledgments, or any message that is NOT a direct expense-processing directive. ALWAYS pick this route when Process_Expense_From_Image does not match — never leave the user without a response."


subagent Acknowledge_Image_Upload:
    label: "Acknowledge Image Upload"
    description: "Fallback route — use this when the user's message does NOT contain any expense-processing directive. Includes: bare image uploads without a caption, greetings like 'Hi' / 'Hello', small talk, and any message where the user hasn't asked to process an expense. If the message contains 'process', 'expense', 'receipt', or 'log', do NOT route here — route to Process_Expense_From_Image instead."
    reasoning:
        instructions: ->
            | The user sent a greeting, small talk, or a message that isn't an expense-processing request. Respond with a short, friendly orientation telling them what you can help with. Do NOT claim that a document was received. Do not call any actions.
            | Respond with exactly this message, verbatim: "I'm here to help you with processing expenses and other post-visit tasks. Just share a receipt with the caption 'process my expenses' and I'll log it for you."

subagent Process_Expense_From_Image:
    label: "Process Expense From Image"
    description: "Route here when the user's message contains ANY expense-processing directive like 'process my expenses', 'process the expense', 'process this receipt', 'log this receipt', 'log expense', 'add expense', 'expense this', or any variant that signals the user wants to log/process/submit an expense. Fire on these keywords regardless of whether the current message has an image attachment — the Apex action will find the most recent image on the messaging session. This is the PRIMARY action for this agent."

    reasoning:
        instructions: ->
            | The user wants you to process an expense from a receipt image they've sent. Call the ProcessExpenseFromImage action ONCE using the current messaging session Id. Then reply to the user with the EXACT text from the action's confirmationMessage output — do not paraphrase, do not summarize, do not add or remove any detail. Do not invent your own response. Do not call the action more than once.

        actions:
            ProcessExpenseFromImage: @actions.ProcessExpenseFromImage
                with messagingSessionIds = @variables.RoutableId

    actions:
        ProcessExpenseFromImage:
            description: "Processes a receipt image from the current messaging session. Reads the latest image, extracts expense fields via a vision prompt template, creates an Expense record, attaches the image to the record, and returns a confirmation message."
            label: "Process Expense From Image"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Processing your receipt"
            target: "apex://ProcessExpenseFromImage"
            inputs:
                messagingSessionIds: string
                    description: "The current messaging session Id, bound from @variables.RoutableId."
                    label: "Messaging Session Id"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"
            outputs:
                success: object
                    description: "Whether the expense was successfully created."
                    label: "Success"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__booleanType"
                expenseId: object
                    description: "Id of the newly created Expense, or null on failure."
                    label: "Expense Id"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"
                amount: object
                    description: "The extracted amount."
                    label: "Amount"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__numberType"
                expenseType: string
                    description: "The extracted expense type."
                    label: "Expense Type"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"
                venue: string
                    description: "The extracted venue / merchant."
                    label: "Venue"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"
                confirmationMessage: string
                    description: "The confirmation message to relay verbatim to the user."
                    label: "Confirmation Message"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"

connection messaging:
    adaptive_response_allowed: True
